{
  "name": "solana-claude",
  "version": "1.0.0",
  "description": "Open-source Solana AI agent framework — Claude Code + SolanaOS architecture, no private key required",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "solana-claude": "src/entrypoints/cli.tsx"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json --watch",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc --noEmit",
    "mcp:build": "cd mcp-server && npm install && npm run build",
    "mcp:start": "cd mcp-server && npm start",
    "mcp:http": "cd mcp-server && npm run start:http",
    "setup": "bash scripts/setup.sh"
  },
  "dependencies": {
