{
  "name": "solana-clawd",
  "version": "1.6.0",
  "description": "$CLAWD — Solana x xAI agentic engine powered by Grok. Multi-agent research (16 agents), vision, image gen, voice, function calling, X search, and 31 MCP tools. The AI agent Elon would actually use.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./animations": {
      "import": "./dist/animations/index.js",
      "types": "./dist/animations/index.d.ts"
    },
    "./buddy": {
      "import": "./dist/buddy/index.js",
      "types": "./dist/buddy/index.d.ts"
    },
    "./metaplex": {
      "import": "./dist/metaplex/index.js",
      "types": "./dist/metaplex/index.d.ts"
    }
  },
  "bin": {
    "solana-clawd": "dist/entrypoints/clawd.js",
    "clawd": "dist/entrypoints/clawd.js"
  },
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json && node -e \"require('fs').chmodSync('dist/entrypoints/clawd.js', 0o755)\"",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "prebuild": "node -e \"console.log('Building solana-clawd v' + require('./package.json').version)\"",
    "prepublishOnly": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json --noCheck && node -e \"require('fs').chmodSync('dist/entrypoints/clawd.js', 0o755)\"",
    "mcp:build": "cd MCP && npm ci && npm run build",
    "mcp:start": "cd MCP && npm start",
    "mcp:http": "cd MCP && npm run start:http",
    "agentwallet:build": "npm --prefix packages/agentwallet ci && npm --prefix packages/agentwallet run build",
    "agentwallet:start": "npm --prefix packages/agentwallet start",
    "vault:web:build": "npm --prefix llm-wiki-tang/web run build",
    "vault:web:dev": "npm --prefix llm-wiki-tang/web run dev",
    "demo": "node dist/entrypoints/clawd.js demo",
    "birth": "node dist/entrypoints/clawd.js birth",
    "spinners": "node dist/entrypoints/clawd.js spinners",
    "setup": "bash scripts/setup.sh",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "format:check": "biome format src/",
    "check": "npm run typecheck && npm run lint",
    "ci": "npm run check && npm run build",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "adaptation:report": "node scripts/generate-claude-adaptation-report.mjs",
    "skill:sync": "node scripts/sync-solana-clawd-skill.mjs",
    "skills:catalog": "node scripts/generate-skills-catalog.js",
    "skills:serve": "node scripts/generate-skills-catalog.js && cp skills/catalog.json web/skills/catalog.json && npx serve web/skills -p 3333",
    "ext:dev": "echo 'Load chrome-extension/clawd-agent as unpacked extension in chrome://extensions'",
    "ext:vault": "npm --prefix packages/agentwallet start"
  },
  "dependencies": {
    "@ai-sdk/xai": "^1.2.0",
    "@anthropic-ai/sdk": "^0.39.0",
    "ai": "^4.3.0",
    "openai": "^4.80.0",
    "@cloudflare/sandbox": "^0.8.4",
    "@commander-js/extra-typings": "^13.1.0",
    "@growthbook/growthbook": "^1.4.0",
    "@metaplex-foundation/mpl-agent-registry": "^0.2.5",
    "@metaplex-foundation/mpl-core": "^1.9.1",
    "@metaplex-foundation/umi": "^1.5.1",
    "@metaplex-foundation/umi-bundle-defaults": "^1.5.1",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.57.0",
    "@opentelemetry/core": "^1.30.0",
    "@opentelemetry/sdk-logs": "^0.57.0",
    "@opentelemetry/sdk-metrics": "^1.30.0",
    "@opentelemetry/sdk-trace-base": "^1.30.0",
    "@solana-tracker/data-api": "^0.2.3",
    "@solana/web3.js": "^1.95.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-unicode11": "^0.8.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "agentwallet-vault": "^0.1.0",
    "auto-bind": "^5.0.1",
    "axios": "^1.7.0",
    "bs58": "^6.0.0",
    "chalk": "^5.4.0",
    "chokidar": "^4.0.0",
    "cli-boxes": "^3.0.0",
    "code-excerpt": "^4.0.0",
    "diff": "^7.0.0",
    "ethers": "^6.13.0",
    "execa": "^9.5.0",
    "express": "^4.21.0",
    "figures": "^6.1.0",
    "fuse.js": "^7.0.0",
    "highlight.js": "^11.11.0",
    "ignore": "^6.0.0",
    "lodash-es": "^4.17.21",
    "marked": "^15.0.0",
    "node-pty": "^1.1.0",
    "p-map": "^7.0.0",
    "picomatch": "^4.0.0",
    "proper-lockfile": "^4.1.2",
    "qrcode": "^1.5.0",
    "react": "^19.0.0",
    "react-reconciler": "^0.31.0",
    "semver": "^7.6.0",
    "solana-claude": "^1.0.0",
    "stack-utils": "^2.0.6",
    "strip-ansi": "^7.1.0",
    "supports-hyperlinks": "^3.1.0",
    "tree-kill": "^1.2.2",
    "tweetnacl": "^1.0.3",
    "type-fest": "^4.30.0",
    "undici": "^7.3.0",
    "unicode-animations": "^1.0.3",
    "usehooks-ts": "^3.1.0",
    "wrap-ansi": "^9.0.0",
    "ws": "^8.18.0",
    "yaml": "^2.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@alcalzone/ansi-tokenize": "^0.3.0",
    "@aws-sdk/credential-provider-node": "^3.972.30",
    "@biomejs/biome": "^1.9.0",
    "@opentelemetry/exporter-logs-otlp-grpc": "^0.214.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-logs-otlp-proto": "^0.214.0",
    "@opentelemetry/exporter-metrics-otlp-grpc": "^0.214.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.214.0",
    "@opentelemetry/exporter-prometheus": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.214.0",
    "@smithy/node-http-handler": "^4.5.2",
    "@types/bun": "^1.3.11",
    "@types/diff": "^7.0.0",
    "@types/express": "^5.0.6",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.14.0",
