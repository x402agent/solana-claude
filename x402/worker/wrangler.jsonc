{
  "$schema": "https://unpkg.com/wrangler/config-schema.json",
  "name": "solanaclawd-x402-gateway",
  "main": "src/index.ts",
  "compatibility_date": "2025-01-15",
  "compatibility_flags": ["nodejs_compat"],

  "routes": [
    { "pattern": "solanaclawd.com/x402/*", "zone_name": "solanaclawd.com" },
    { "pattern": "ipfs.solanaclawd.com/*", "zone_name": "solanaclawd.com" }
  ],

  "vars": {
    "NETWORK": "solana-mainnet",

    // Treasury ATA owner (Squads multisig). Payments flow in here first, then split by clawd-vault.
    "TREASURY_OWNER": "REPLACE_WITH_SQUADS_MULTISIG_PUBKEY",

    // SPL USDC mainnet mint
    "USDC_MINT": "EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v",

    // $CLAWD mint (replace with the real mint once finalised)
    "CLAWD_MINT": "REPLACE_WITH_CLAWD_MINT",

    // ClawdVault Anchor program ID
    "CLAWD_VAULT_PROGRAM": "REPLACE_WITH_PROGRAM_ID",

    // Agent registry PDA seed
    "REGISTRY_SEED": "clawd-registry-v1",

    // Pinata gateway base
    "PINATA_GATEWAY": "https://ipfs.solanaclawd.com",

    // Revenue split basis points (10000 = 100%)
    "SPLIT_OWNER_BPS": 7000,
    "SPLIT_BUYBACK_BPS": 1500,
    "SPLIT_TREASURY_BPS": 1000,
    "SPLIT_OPERATOR_BPS": 500,

    // $CLAWD holder discount tiers in base units (9 decimals assumed)
    "DISCOUNT_TIER_1_BALANCE": "100000000000000",    // 100k
    "DISCOUNT_TIER_1_BPS": 1000,                     // 10%
    "DISCOUNT_TIER_2_BALANCE": "1000000000000000",   // 1M
    "DISCOUNT_TIER_2_BPS": 2500,                     // 25%
    "DISCOUNT_TIER_3_BALANCE": "10000000000000000",  // 10M
    "DISCOUNT_TIER_3_BPS": 5000                      // 50%
  }

  // Secrets (set via `wrangler secret put`):
  //   HELIUS_API_KEY        RPC access
  //   SOLANATRACKER_API_KEY Fallback RPC + data
  //   PINATA_JWT            Pinata pin JWT
  //   OPERATOR_KEYPAIR      base58-encoded Ed25519 secret key for the settlement operator
  //   AP2_VERIFIER_JWK      Public JWK for verifying AP2 Verifiable Credentials
}
