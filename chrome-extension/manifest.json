{
  "manifest_version": 3,
  "name": "Solana Clawd — pAGENT Browser",
  "short_name": "Clawd",
  "version": "2.0.0",
  "description": "Solana Clawd browser companion with pAGENT GUI vision. Wallet vault, chat, tools, Seeker mobile gateway, and native daemon access from one extension.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    },
    "default_title": "Solana Clawd — pAGENT Browser"
  },
  "permissions": [
    "storage",
    "activeTab",
    "alarms"
  ],
  "host_permissions": [
    "http://127.0.0.1:7777/*",
    "http://127.0.0.1:18800/*",
    "http://127.0.0.1:18790/*",
    "http://localhost:7777/*",
    "http://localhost:18800/*",
    "http://localhost:18790/*",
    "http://127.0.0.1:8420/*",
    "http://localhost:8420/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
