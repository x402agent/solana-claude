# .env.example — copy to .env and fill in values
# NO PRIVATE KEYS REQUIRED for read-only / MCP mode.
# Only needed if you want the standalone agent to call LLMs directly.

# ─── LLM Provider (OPTIONAL — MCP mode uses Claude Desktop's built-in model) ──
# Get a free key at https://openrouter.ai (free models available)
OPENROUTER_API_KEY=

# Or use xAI Grok (free tier at https://console.x.ai)
XAI_API_KEY=

# Or Anthropic directly
ANTHROPIC_API_KEY=

# ─── Solana RPC (OPTIONAL — defaults to public mainnet-beta) ──────────────────
# Get a free Helius key at https://www.helius.dev (1M credits/month free)
HELIUS_API_KEY=
# Falls back to: https://api.mainnet-beta.solana.com (public, no key needed)

# ─── MCP Server auth (OPTIONAL — leave blank for open access) ────────────────
# Set this if you deploy the MCP server publicly and want to restrict access
MCP_API_KEY=

# ─── Fly.io deployment (OPTIONAL) ────────────────────────────────────────────
# Set when deploying: fly secrets set SOLANAOS_GATEWAY_URL=...
SOLANAOS_GATEWAY_URL=http://localhost:8080
