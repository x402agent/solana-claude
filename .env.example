# .env.example — copy to .env and fill in values
# NO PRIVATE KEYS REQUIRED for read-only / MCP mode.

# ─── Helius (RECOMMENDED — free at helius.dev, 1M credits/month) ──────────────
# Helius gives you:
#   - Ultra-low latency RPC (Gatekeeper beta)
#   - Enhanced WebSockets (transactionSubscribe with account filtering)
#   - LaserStream gRPC (mission-critical low latency)
#   - DAS (Digital Asset Standard) — NFT/token metadata
#   - Webhooks — server-side event notifications
#   - Enhanced transaction parsing
# Get your free key: https://www.helius.dev
HELIUS_API_KEY=

# RPC endpoint (HTTP) — auto-built from HELIUS_API_KEY if not set
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=${HELIUS_API_KEY}

# WebSocket endpoint — for real-time onchain event listening
HELIUS_WSS_URL=wss://mainnet.helius-rpc.com/?api-key=${HELIUS_API_KEY}

# ─── LLM Provider (OPTIONAL — MCP mode uses Claude Desktop's model) ───────────
# Free models via OpenRouter: https://openrouter.ai (no CC required for free tier)
OPENROUTER_API_KEY=
# Or xAI Grok: https://console.x.ai
XAI_API_KEY=
# Or Anthropic directly
ANTHROPIC_API_KEY=

# ─── Solana data (OPTIONAL — public APIs work without keys) ───────────────────
# SolanaTracker — enhanced token data, trending, PnL
# Free key: https://data.solanatracker.io
SOLANA_TRACKER_API_KEY=

# ─── MCP Server auth (OPTIONAL — leave blank for open access) ────────────────
# Set this if deploying publicly. Leave blank for local/Claude Desktop use.
MCP_API_KEY=

# ─── Helius Webhooks (OPTIONAL — for receiving webhook POSTs) ─────────────────
# If you set up Helius webhooks to POST to your server, set this to verify them
HELIUS_WEBHOOK_AUTH=

# ─── Fly.io deployment (OPTIONAL) ────────────────────────────────────────────
SOLANAOS_GATEWAY_URL=http://localhost:8080

# ─── x402 Micropayments (OPTIONAL — Solana USDC payment protocol) ─────────────
# x402 enables the agent to pay for premium API access via HTTP 402 payment flow.
# Compatible with any x402-enabled API (https://github.com/coinbase/x402).
# Solana is the primary payment rail (USDC, ~0.00001 SOL per payment).
#
# To get a devnet keypair for testing:
#   solana-keygen new --outfile ~/.config/solana/devnet.json
#   solana config set --keypair ~/.config/solana/devnet.json
#   solana airdrop 1 --url devnet
#
# Base58-encoded full keypair (64 bytes = privkey + pubkey)
X402_SVM_PRIVATE_KEY=
X402_NETWORK=solana             # solana|solana-devnet|base|base-sepolia
X402_MAX_PER_REQUEST_USD=0.10   # Max $0.10 per single API call
X402_MAX_SESSION_USD=5.00       # Max $5.00 per session
X402_FACILITATOR_URL=           # Leave blank for default (https://x402.org/facilitator)

# EVM fallback (optional — for Base/Ethereum x402 payments)
X402_EVM_PRIVATE_KEY=

# ─── autoDream — memory consolidation (OPTIONAL) ─────────────────────────────
# autoDream promotes INFERRED signals → LEARNED after N OODA cycles
DREAM_MIN_CYCLES=5   # Minimum OODA cycles before consolidation (default: 5)
DREAM_MIN_HOURS=6    # Minimum hours between dreams (default: 6h)
DREAM_ENABLED=true   # Set to false to disable background consolidation

# ─── Session memory (OPTIONAL) ───────────────────────────────────────────────
# Sessions saved to ~/.config/solana-claude/sessions/
SESSION_MAX_MESSAGES=100  # Compact messages after this count (default: 100)
